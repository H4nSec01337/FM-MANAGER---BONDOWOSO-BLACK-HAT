// Fungsi baca isi folder (multi metode)
function l($d){
    $a=[];
    if(function_exists('scandir')){
        $s=@scandir($d);
        if($s)foreach($s as $i)if($i!='.'&&$i!='..')$a[]=$i;
        return $a;
    }
    if(function_exists('glob')){
        $g=@glob($d.'/*');
        if($g)foreach($g as $i)$a[]=basename($i);
        return $a;
    }
    return [];
}
$i=l($c);
sort($i);

// Fungsi ukuran
function s($b){if($b>=1073741824)return round($b/1073741824,2).' GB';if($b>=1048576)return round($b/1048576,2).' MB';if($b>=1024)return round($b/1024,2).' KB';return $b.' B';}

